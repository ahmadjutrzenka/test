            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ahmad\",\n  \"email\": \"ahmad@mail.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register — email sudah dipakai Google",
